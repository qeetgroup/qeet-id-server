# Caddy: automatic HTTPS (Let's Encrypt) + reverse proxy to the backend.
# QEETID_DOMAIN is injected from the environment (see docker-compose.prod.yml).

{$QEETID_DOMAIN} {
	encode gzip zstd

	# Security headers (Caddy adds HSTS automatically on HTTPS sites).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# /metrics is internal-only: never expose Prometheus scrape data publicly.
	# Scrape it from the internal network (Prometheus container) instead.
	@metrics path /metrics
	respond @metrics 404

	reverse_proxy backend:4000 {
		health_uri /healthz
		health_interval 10s
		health_timeout 2s
	}
}
