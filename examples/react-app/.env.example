# Qeet ID React SPA example — copy to .env.local before running.
# Matches the PUBLIC demo client created by the backend dev seed (qci_example_spa).
# Dev only. Vite exposes only VITE_-prefixed vars to the browser.

VITE_QEETID_API_URL=http://localhost:4001
VITE_QEETID_CLIENT_ID=qci_example_spa
VITE_QEETID_REDIRECT_URI=http://localhost:3020/callback
VITE_QEETID_POST_LOGOUT_URI=http://localhost:3020
VITE_QEETID_SCOPES=openid profile email
