# Qeetid Admin — environment variables
# Copy this file to `.env` (gitignored) and fill in real values for local dev.
# Schema: src/env.ts

# --- Client (exposed to the browser, must be prefixed with VITE_) ---

# Window title and visible app name
VITE_APP_TITLE="Qeetid Admin"

# Backend API base URL (used by fetch calls from the browser)
# VITE_API_URL="http://localhost:8080"


# --- Server (Node-only, never sent to the browser) ---

# Internal server URL (used by SSR / server functions)
# SERVER_URL="http://localhost:8080"


# --- Vercel auto-injected at deploy time — DO NOT set locally ---
# VERCEL=1                 ← "1" when running on Vercel
# VERCEL_ENV=production    ← "production" | "preview" | "development"
# VERCEL_URL=...           ← the deployment hostname
