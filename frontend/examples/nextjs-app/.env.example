# Qeet ID example app — copy to .env.local before running.
# These values match the demo OAuth client created by the backend dev seed
# (make -C backend seed-reset). Dev only — never use these in production.

# OAuth client (seeded by backend/cmd/seed as "qci_example_app").
QEETID_CLIENT_ID=qci_example_app
QEETID_CLIENT_SECRET=example-app-dev-secret-change-me

# Qeet ID backend (local dev default port).
QEETID_API_URL=http://localhost:4001

# This example app's own base URL (must match the seeded redirect URI).
QEETID_APP_URL=http://localhost:3010

# Secret used to encrypt the session cookie. Must be ≥32 chars. Dev value only.
QEETID_COOKIE_SECRET=dev-only-cookie-secret-change-me-0123456789

# OIDC scopes to request.
QEETID_SCOPES="openid profile email"
