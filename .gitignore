# macOS
.venv
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# Editors / IDEs
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# Claude Code — keep shared config (settings.json, commands/, agents/, README.md),
# ignore personal overrides and runtime artifacts.
.claude/settings.local.json
.claude/.cache/
.claude/.session/
.claude/logs/

# graphify output (regenerated on demand)
graphify-out/

# Go — build output, test/coverage artifacts (merged from backend/.gitignore on hoist)
/bin/
*.test
*.out
coverage.html

# JS/Node — deps, stores, build outputs (merged from frontend/.gitignore on hoist)
node_modules/
.pnpm-store/
dist/
build/
.next/
.nitro/
.output/
.tanstack/
coverage/

# Env / secrets — never commit (but keep .env*.example templates)
.env
.env.local
.env.*.local
.env.prod
.env.staging
.env.production
# …but the frontend apps' .env.production hold only PUBLIC NEXT_PUBLIC_/VITE_
# build-time config (no secrets) — version-control them.
!apps/website/.env.production
!apps/console/.env.production
!apps/login/.env.production
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Tooling caches
.cache/
.turbo/
.eslintcache
*.tsbuildinfo

# OS / archive
*.tar
*.tar.gz
*.zip
