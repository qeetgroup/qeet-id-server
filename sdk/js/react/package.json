{
  "name": "@qeet-id/react",
  "version": "0.2.0",
  "description": "React client components & hooks for Qeet ID — <QeetIDProvider>, useAuth/useUser, <SignedIn>/<SignedOut>, <SignInButton>/<SignUpButton>/<SignOutButton>, branded <SignInWithQeet>/<SignUpWithQeet>/<ContinueWithQeet>, and <UserButton>.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path ../../.prettierignore",
    "check": "eslint . --ext .ts,.tsx && prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@qeet-id/client": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  }
}
