SERVICE_NAME=qeet-id
SERVICE_ENV=dev
HTTP_PORT=4001
LOG_LEVEL=info

# Postgres credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=qeet_id
POSTGRES_PORT=5001
DB_MIN_CONNS=2
DB_MAX_CONNS=10

# 32-byte random hex; used for signing access & refresh tokens in dev.
# In prod, swap to RS256 with JWKS.
JWT_SECRET=please-change-me-please-change-me
JWT_ISSUER=qeet-id
JWT_AUDIENCE=qeet-id
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3000,http://localhost:5173

# Dev-only: trust X-Dev-User / X-Dev-Tenant headers (Postman shortcut).
AUTH_DEV_TRUST_HEADERS=true

# Dev-only:
CSRF_DISABLED=true
