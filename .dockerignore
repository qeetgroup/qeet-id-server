# Build context is the REPO ROOT (single Go module at root). Keep only what the
# Go image build needs: go.mod/go.sum + cmd/ domains/ platform/. Everything else
# is excluded.

# Git
.git
.gitignore
.gitattributes

# Infra / deploy / docs / codegen inputs / tests — not needed to build the binary
# (platform/database/migrations IS kept: embedded via //go:embed at compile time)
deploy/
docs/
graphify-out/
tests/
# api/ holds specs (openapi, postman) AND a Go package (api/copilot, embedded
# tools manifest imported by the binary) — exclude the specs, keep the code.
api/openapi/
api/postman/

# Build artifacts
bin/
*.exe
*.test
*.out
coverage.html
coverage.txt

# Env / secrets
.env
.env.*
!.env.example

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo

# Docs/build files that don't ship in the image
README.md
CHANGELOG.md
Makefile
Dockerfile

# CI
.github/
