{
  "name": "@qeet-id/node",
  "version": "0.2.0",
  "description": "Node.js server-side SDK for Qeet ID — users, tenants, authorization, and session/JWT verification.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=24"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\" --ignore-path ../../.prettierignore",
    "check": "eslint . --ext .ts && prettier --check \"**/*.{ts,json,md}\" --ignore-path ../../.prettierignore"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
