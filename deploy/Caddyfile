# SITE_ADDRESS comes from .env:
#   api.id.qeet.in  -> Caddy obtains + renews a Let's Encrypt cert automatically
#   :80             -> plain HTTP, for first bring-up before DNS/TLS is ready
{$SITE_ADDRESS::80} {
	encode zstd gzip

	reverse_proxy app:4001 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}
}
