SERVICE_NAME=qeet-id
SERVICE_ENV=dev
HTTP_PORT=4001
LOG_LEVEL=info

# Postgres connection string (matches docker-compose.yml); used for queries + migrations.
DB_URL=postgres://postgres:<password>@localhost:5001/qeet_id?sslmode=disable
# Outbox dispatcher publishes domain events here; blank = log-only.
NATS_URL=nats://127.0.0.1:4222
DB_MIN_CONNS=2
DB_MAX_CONNS=10

# Derives the secrets-vault key (no longer used for token signing).
JWT_SECRET=please-change-me-please-change-me
JWT_ISSUER=qeet-id
JWT_AUDIENCE=qeet-id
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=720h
# ES256 EC P-256 private key (PEM). Blank in dev = ephemeral key; REQUIRED outside dev.
#   Generate: openssl ecparam -name prime256v1 -genkey -noout
JWT_SIGNING_KEY=
# Concatenated PEM public keys of retired signing keys, kept verifiable during rotation.
JWT_RETIRED_KEYS=
# base64 AES key (16/24/32 bytes) for the secrets vault. Blank in dev = ephemeral; REQUIRED outside dev.
#   Generate: openssl rand -base64 32
SECRETS_KEY=

# Breached-password check (HIBP range API). Needs network + fails open, so off by default;
# turn on for staging/prod. An offline common-password denylist always runs.
BREACHED_PASSWORD_CHECK=false
BREACHED_PASSWORD_MIN_COUNT=1

# Browser origins allowed to call the API cross-origin (CORS).
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3000,http://localhost:5173

# Origin for links in emails. Dev: admin app (:3002) hosts /invite/accept.
APP_BASE_URL=http://localhost:3002

# Hosted login app origin — the OAuth authorize flow redirects here.
LOGIN_BASE_URL=http://localhost:3003

# ── Notifications ─────────────────────────────────────────────────────────
# SMTP (SES/SendGrid/Mailgun/Postmark…). Blank SMTP_HOST in dev = log instead of send.
# For real delivery, set SPF/DKIM/DMARC on the sending domain.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Qeet ID <noreply@qeet.in>
# Twilio (SMS-OTP). Blank = log instead of send.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Scaling ───────────────────────────────────────────────────────────────
# Enables shared cross-replica rate limiting; blank = in-process (single instance only).
# Example: redis://localhost:6379/0  (rediss://… for TLS)
REDIS_URL=

# WebAuthn / passkeys RP. Blank RP_ID/name defaults to the APP_BASE_URL host + SERVICE_NAME.
WEBAUTHN_RP_ID=
WEBAUTHN_RP_DISPLAY_NAME=
# Must list every browser origin that runs a passkey ceremony (registration :3002, login :3003).
WEBAUTHN_RP_ORIGINS=http://localhost:3002,http://localhost:3003,http://localhost:3001

# Dev-only: trust X-Dev-User / X-Dev-Tenant headers (Postman shortcut).
AUTH_DEV_TRUST_HEADERS=true

# ── AI Copilot ────────────────────────────────────────────────────────────
# Admin-console copilot. Blank COPILOT_PROVIDER disables it (CRUD still works, messages 409).
# PROVIDER: "anthropic" or "openai"; "openai" also drives any OpenAI-compatible endpoint via BASE_URL.
# API_KEY: server-side only, never returned. MODEL: provider model id. BASE_URL: blank = provider default.
#   anthropic  → BASE_URL blank,                              MODEL=claude-sonnet-5
#   openai     → BASE_URL blank,                              MODEL=gpt-4o
#   groq       → BASE_URL=https://api.groq.com/openai/v1,     MODEL=llama-3.1-70b-versatile
#   openrouter → BASE_URL=https://openrouter.ai/api/v1,       MODEL=anthropic/claude-sonnet-5
#   gemini     → BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/, MODEL=gemini-2.0-flash
COPILOT_PROVIDER=
COPILOT_API_KEY=
COPILOT_MODEL=
COPILOT_MAX_TOKENS=4096
COPILOT_BASE_URL=

# Dev-only:
CSRF_DISABLED=true

# Prod: scope the CSRF cookie across sibling subdomains (e.g. ".id.qeet.in"). Blank in dev.
CSRF_COOKIE_DOMAIN=
