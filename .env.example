SERVICE_NAME=qeet-id
SERVICE_ENV=dev
HTTP_PORT=4001
LOG_LEVEL=info

# Postgres connection string (matches the local dev DB in docker-compose.yml)
DB_URL=postgres://postgres:password@localhost:5001/qeet_id?sslmode=disable
DB_MIN_CONNS=2
DB_MAX_CONNS=10
# OPTIONAL — Row-Level-Security activation. Leave blank for the simple single-role
# setup (migrations + runtime both use DB_URL; RLS is present but inert because the
# superuser bypasses it). To ENFORCE tenant isolation at the DB layer, point DB_URL
# at the dedicated non-superuser role `qeet_app` (created by migration 0082; grant it
# LOGIN + a password once: `ALTER ROLE qeet_app WITH LOGIN PASSWORD '…';`) and set
# DB_MIGRATE_URL to an owner/superuser role so migrations can still run DDL.
#   DB_URL=postgres://qeet_app:<secret>@localhost:5001/qeet_id?sslmode=disable
#   DB_MIGRATE_URL=postgres://postgres:password@localhost:5001/qeet_id?sslmode=disable
DB_MIGRATE_URL=

# Server secret (32-byte random hex). No longer used for token signing — it
# now only derives the secrets-vault key (until that moves to KMS, P0-6).
JWT_SECRET=please-change-me-please-change-me
JWT_ISSUER=qeet-id
JWT_AUDIENCE=qeet-id
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=720h
# Access & ID tokens are signed with ES256 using this PEM EC P-256 private key,
# and the public half is published at /.well-known/jwks.json so relying parties
# can verify them. Leave blank in dev to auto-generate an ephemeral key at
# startup (tokens won't survive a restart). REQUIRED outside SERVICE_ENV=dev.
#   Generate:  openssl ecparam -name prime256v1 -genkey -noout
# Multi-line PEMs are awkward in .env — prefer a mounted file / secret manager.
JWT_SIGNING_KEY=
# Optional: one or more concatenated PEM PUBLIC keys of previously-active
# signing keys, kept verifiable during the rotation grace window.
JWT_RETIRED_KEYS=
# SECRETS_KEY: base64 AES key (16/24/32 bytes) for the per-tenant secrets vault,
# independent of JWT_SECRET. Leave blank in dev to auto-generate an ephemeral
# key (stored secrets won't survive a restart). REQUIRED outside SERVICE_ENV=dev.
#   Generate:  openssl rand -base64 32
# Production should source this from a KMS-wrapped key (see internal/secret).
SECRETS_KEY=

# Breached-password check (Have I Been Pwned k-anonymity range API). OFF by
# default because it needs network and fails open. Turn ON for staging/prod so
# breached passwords are rejected on signup, password reset, invite-accept and
# set-password. An offline common-password denylist always runs regardless.
#   BREACHED_PASSWORD_CHECK=true
BREACHED_PASSWORD_CHECK=false
# Breach-sighting threshold at or above which a password is rejected.
BREACHED_PASSWORD_MIN_COUNT=1

# NB: :3020 is the React SPA example (frontend/examples/react-app) — it does the
# OAuth token/userinfo calls cross-origin from the browser, so its origin must be allowed.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3000,http://localhost:5173,http://localhost:3020

# Frontend origin used to build links in emails (password reset, magic links, invites).
# Dev: the admin app (:3002) hosts /invite/accept, so point invite links there.
APP_BASE_URL=http://localhost:3002

# Hosted login app (qeetid-login) origin — the OAuth authorize flow redirects
# here for sign-in and consent.
LOGIN_BASE_URL=http://localhost:3004

# ── Notifications ─────────────────────────────────────────────────────────
# Email via SMTP (provider-agnostic: Amazon SES, SendGrid, Mailgun, Postmark…).
# Leave SMTP_HOST blank in dev to log emails instead of sending. For real
# delivery also set up SPF, DKIM, and DMARC on the sending domain.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Qeet ID <noreply@qeet.in>
# SMS via Twilio (used for SMS-OTP). Leave blank to log instead of sending.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Scaling ───────────────────────────────────────────────────────────────
# REDIS_URL enables shared, cross-replica rate limiting. Leave blank for
# in-process limits (correct only when running a single instance).
# Example: redis://localhost:6379/0  (or rediss://… for TLS)
REDIS_URL=

# NATS_URL enables real cross-product event fan-out: the outbox dispatcher
# publishes drained domain events to NATS (subject = event topic, e.g.
# "user.events"). Leave blank to keep the dependency-free log-only publisher
# (fine for single-product / self-host). Example: nats://localhost:4222
NATS_URL=

# WebAuthn / passkeys Relying Party. Leave RP_ID / display name blank to default
# RP_ID to the APP_BASE_URL host (localhost — port-agnostic) and the name to
# SERVICE_NAME.
WEBAUTHN_RP_ID=
WEBAUTHN_RP_DISPLAY_NAME=
# RP_ORIGINS must list EVERY browser origin that runs a passkey ceremony. Passkey
# registration happens in the admin app (:3002) but passwordless LOGIN happens in
# the hosted login app (:3004), so both must be allowed (and the marketing app
# :3001 if it ever offers passkeys). If blank it defaults to just APP_BASE_URL
# (:3002), and passkey login on :3004 fails origin validation.
WEBAUTHN_RP_ORIGINS=http://localhost:3002,http://localhost:3004,http://localhost:3001

# Dev-only: trust X-Dev-User / X-Dev-Tenant headers (Postman shortcut).
AUTH_DEV_TRUST_HEADERS=true

# Dev-only:
CSRF_DISABLED=true

# Prod: scope the CSRF cookie across sibling subdomains so the hosted login app
# can read the double-submit token issued by the API (e.g. ".id.qeet.in").
# Leave blank in dev (single host).
CSRF_COOKIE_DOMAIN=
