# Qeet ID — Production Environment Variables
# Copy to .env and fill in every blank value.
# Generate secrets: see deploy.md

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_ENV=prod
HTTP_PORT=4001
LOG_LEVEL=info

# ── Database (AWS RDS) ────────────────────────────────────────────────────────
DB_URL=postgres://qeetid:CHANGE_ME@your-db.xxxx.us-east-1.rds.amazonaws.com:5432/qeet_id?sslmode=require
DB_MIN_CONNS=2
DB_MAX_CONNS=20

# ── JWT ───────────────────────────────────────────────────────────────────────
# openssl rand -base64 48
JWT_SECRET=
# EC P-256 PEM, single line with \n  (see deploy.md)
JWT_SIGNING_KEY=
JWT_ISSUER=https://api.id.qeet.in
JWT_AUDIENCE=qeet-id
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# ── Secrets vault ─────────────────────────────────────────────────────────────
SECRETS_PROVIDER=static
# openssl rand -base64 32
SECRETS_KEY=

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://console.id.qeet.in
LOGIN_BASE_URL=https://auth.id.qeet.in
ALLOWED_ORIGINS=https://console.id.qeet.in,https://auth.id.qeet.in

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── WebAuthn / Passkeys ───────────────────────────────────────────────────────
WEBAUTHN_RP_ID=id.qeet.in
WEBAUTHN_RP_DISPLAY_NAME=Qeet ID
WEBAUTHN_RP_ORIGINS=https://auth.id.qeet.in,https://console.id.qeet.in

# ── CSRF ──────────────────────────────────────────────────────────────────────
# openssl rand -base64 32
CSRF_KEY=
CSRF_COOKIE_DOMAIN=.id.qeet.in

# ── SAML IdP ──────────────────────────────────────────────────────────────────
# RSA PEM, single line with \n  (see deploy.md)
SAML_IDP_KEY=
SAML_IDP_CERT=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@id.qeet.in

# ── SMS (Twilio) — optional ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Breach-password detection ─────────────────────────────────────────────────
BREACHED_PASSWORD_CHECK=true
BREACHED_PASSWORD_MIN_COUNT=1

# ── Payments — disabled until keys are set ───────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── Observability — optional ──────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
