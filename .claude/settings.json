{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy)",
      "Bash(go mod download)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(pnpm install)",
      "Bash(pnpm i)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm check:*)",
      "Bash(pnpm dlx:*)",
      "Bash(turbo run:*)",
      "Bash(migrate -path migrations -database * up)",
      "Bash(migrate -path migrations -database * version)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose up -d)",
      "Bash(docker compose down)",
      "Bash(lsof -nP -iTCP:*)",
      "Bash(ls:*)",
      "Bash(find . -name:*)",
      "Bash(find . -type:*)",
      "Bash(find backend:*)",
      "Bash(find frontend:*)",
      "Bash(find documents:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git stash list)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh api:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -i http://localhost:*)",
      "Bash(curl http://localhost:*)",
      "Bash(newman run:*)",
      "Bash(./run.sh:*)",
      "Read",
      "Edit",
      "Write(backend/**)",
      "Write(frontend/**)",
      "Write(documents/**)",
      "Write(.claude/**)",
      "Write(.github/**)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:go.dev)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:vitejs.dev)",
      "WebFetch(domain:turborepo.com)",
      "WebFetch(domain:pnpm.io)",
      "WebFetch(domain:postgresql.org)",
      "WebFetch(domain:openid.net)",
      "WebFetch(domain:datatracker.ietf.org)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git config:*)",
      "Bash(migrate * down:*)",
      "Bash(migrate -path migrations -database * down:*)",
      "Bash(make db-reset)",
      "Bash(make db-wipe)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./**/.env)",
      "Write(./**/.env.*)",
      "Write(./**/*.pem)",
      "Write(./**/*.key)",
      "Write(./secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./**/.env)",
      "Edit(./**/.env.*)",
      "Edit(./**/*.pem)",
      "Edit(./**/*.key)",
      "Edit(./secrets/**)",
      "Edit(./backend/migrations/0001_*)",
      "Edit(./backend/migrations/0002_*)",
      "Edit(./backend/migrations/0003_*)",
      "Edit(./backend/migrations/0004_*)",
      "Edit(./backend/migrations/0005_*)",
      "Edit(./backend/migrations/0006_*)",
      "Edit(./backend/migrations/0007_*)",
      "Edit(./backend/migrations/0008_*)",
      "Edit(./backend/migrations/0009_*)",
      "Edit(./backend/migrations/00[12][0-9]_*)"
    ]
  },
  "env": {
    "QEETID_DB_URL": "postgres://postgres:password@localhost:5001/qeet_identity?sslmode=disable",
    "QEETID_API_BASE": "http://localhost:4000"
  }
}
