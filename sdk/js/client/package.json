{
  "name": "@qeet-id/client",
  "version": "0.2.0",
  "description": "Framework-agnostic browser client for Qeet ID — cookie + CSRF aware, drives the hosted-login auth flows (password, passkeys/WebAuthn, MFA, magic links, social, sessions). Powers the hosted login app and the @qeet-id/react embedded components.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\" --ignore-path ../../.prettierignore",
    "check": "eslint . --ext .ts && prettier --check \"**/*.{ts,json,md}\" --ignore-path ../../.prettierignore"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
