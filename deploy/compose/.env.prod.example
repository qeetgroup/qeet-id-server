# Non-secret production/staging config for docker-compose.prod.yml.
# Copy to .env.prod and fill in. SECRETS (JWT_SECRET, JWT_SIGNING_KEY,
# SECRETS_KEY, SAML_IDP_*, SMTP_PASSWORD, TWILIO_AUTH_TOKEN, POSTGRES_PASSWORD)
# are NOT here — export them in the shell so multiline PEMs survive and secrets
# never land in a committed file. See the header of docker-compose.prod.yml.

# --- runtime ---
# Any value other than "dev" activates config.Validate()'s production gate.
SERVICE_ENV=staging
SERVICE_NAME=qeet-id
HTTP_PORT=4001
LOG_LEVEL=info

# --- public URLs (must be real public origins, not localhost) ---
QEETID_DOMAIN=id.example.com
APP_BASE_URL=https://app.example.com
LOGIN_BASE_URL=https://login.example.com
# Explicit allow-list — a wildcard is rejected with credentialed CORS.
ALLOWED_ORIGINS=https://app.example.com,https://login.example.com
# Scope the CSRF cookie across sibling subdomains.
CSRF_COOKIE_DOMAIN=.example.com

# --- database ---
# POSTGRES_PASSWORD comes from the shell env. DB_URL is assembled in the compose
# file from POSTGRES_* (env_file values aren't interpolated, so it can't live here).
POSTGRES_USER=qeet
POSTGRES_DB=qeet_id
DB_MIN_CONNS=2
DB_MAX_CONNS=20

# --- redis (shared rate limits across replicas) ---
REDIS_URL=redis://redis:6379/0

# --- secrets provider ---
# static  -> SECRETS_KEY (exported in shell)
# aws-kms -> KMS_KEY_ID + SECRETS_WRAPPED_DEK (recommended for AWS)
SECRETS_PROVIDER=static
# KMS_KEY_ID=arn:aws:kms:us-east-1:111122223333:key/abcd-...

# --- observability ---
# Empty disables tracing entirely. Point at your OTLP/HTTP collector to enable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER_RATIO=0.1

# --- email / sms (passwords/tokens via shell env) ---
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_FROM=no-reply@example.com
TWILIO_ACCOUNT_SID=
TWILIO_FROM=

# --- security features ---
BREACHED_PASSWORD_CHECK=true

# --- WebAuthn relying party ---
WEBAUTHN_RP_ID=example.com
WEBAUTHN_RP_DISPLAY_NAME=Qeet ID
WEBAUTHN_RP_ORIGINS=https://app.example.com,https://login.example.com
