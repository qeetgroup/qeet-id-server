# Production build-time config for the Qeet ID admin dashboard (manage.qeet.in).
# Vite inlines VITE_* at build; only public values belong here (no secrets).
VITE_APP_TITLE="Qeet ID Admin"

# Live backend API (the app appends /v1/... itself).
VITE_API_URL="https://id.api.qeet.in"

# Internal/SSR server URL (TanStack Start server functions) — same prod API.
SERVER_URL="https://id.api.qeet.in"
