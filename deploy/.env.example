# Copy to /opt/qeet-id/.env on the EC2 host and fill in real values.
# This file is the template; the real .env is host-only and NEVER committed.
# Values follow the org domain standard (qeet-files/DOMAIN-ARCHITECTURE.md):
# API = api.id.qeet.in, OIDC issuer = https://api.id.qeet.in.

# ── Deploy knobs (read by docker-compose, not the app) ───────────────────
IMAGE=ghcr.io/qeetgroup/qeet-id:latest
SITE_ADDRESS=api.id.qeet.in          # Caddy TLS host; use ":80" before DNS is ready

# ── Core ─────────────────────────────────────────────────────────────────
SERVICE_NAME=qeet-id
SERVICE_ENV=production               # MUST NOT be "dev" (that disables CSRF/auth safety)
HTTP_PORT=4001
LOG_LEVEL=info

# ── Database (RDS) ───────────────────────────────────────────────────────
# sslmode=require — RDS enforces TLS. URL-encode any special chars in the password.
# Current prod uses the master user `postgres` and the default database `postgres`.
DB_URL=postgres://postgres:CHANGE_ME@qeet-id-postgres.ctsgcomag80l.ap-south-2.rds.amazonaws.com:5432/postgres?sslmode=require
DB_MIN_CONNS=2
DB_MAX_CONNS=20

# ── Tokens / OIDC ────────────────────────────────────────────────────────
JWT_ISSUER=https://api.id.qeet.in
JWT_AUDIENCE=qeet-id
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
# 32+ byte secret (derives the secrets-vault key). Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
# JWT_SIGNING_KEY (EC P-256 PEM, ES256) is multi-line, so it is NOT set here.
# Store it on the host as /opt/qeet-id/jwt_signing_key.pem; the deploy step
# exports it into the container's environment. Generate:
#   openssl ecparam -name prime256v1 -genkey -noout > jwt_signing_key.pem
#
# SAML IdP signing identity — required outside dev, also multi-line PEMs kept
# as host files /opt/qeet-id/saml_idp_key.pem (RSA key) + saml_idp_cert.pem
# (X.509 cert); the deploy step exports SAML_IDP_KEY / SAML_IDP_CERT. Generate:
#   openssl req -x509 -newkey rsa:2048 -keyout saml_idp_key.pem \
#     -out saml_idp_cert.pem -days 3650 -nodes -subj "/CN=Qeet ID SAML IdP"

# ── Secrets vault ────────────────────────────────────────────────────────
SECRETS_PROVIDER=static
# base64 AES key (16/24/32 bytes). Generate: openssl rand -base64 32
SECRETS_KEY=CHANGE_ME_openssl_rand_base64_32

# ── Frontends / CORS / cookies (domain standard §6) ──────────────────────
APP_BASE_URL=https://console.id.qeet.in     # admin console (email links + WebAuthn base)
LOGIN_BASE_URL=https://login.id.qeet.in      # hosted login
ALLOWED_ORIGINS=https://id.qeet.in,https://login.id.qeet.in,https://console.id.qeet.in
CSRF_COOKIE_DOMAIN=.id.qeet.in               # product zone — NEVER .qeet.in

# ── Passkeys / WebAuthn ──────────────────────────────────────────────────
WEBAUTHN_RP_ID=id.qeet.in
WEBAUTHN_RP_ORIGINS=https://login.id.qeet.in,https://console.id.qeet.in

# ── Passwords ────────────────────────────────────────────────────────────
BREACHED_PASSWORD_CHECK=true
BREACHED_PASSWORD_MIN_COUNT=1

# ── Email (optional; blank = log instead of send) ────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Qeet ID <noreply@qeet.in>

# ── SMS via Twilio (optional; blank = log instead of send) ───────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Payments (optional; leave blank until wired up) ──────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Scaling (optional) ───────────────────────────────────────────────────
# Single instance => in-process rate limiting is correct; leave REDIS_URL blank.
REDIS_URL=
